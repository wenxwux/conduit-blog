---
interface Props { lang?: 'zh' | 'en'; }
const { lang = 'zh' } = Astro.props;
const year = new Date().getFullYear();
---
<footer>
  <p>
    {lang === 'zh'
      ? `© ${year} Conduit AI Blog · AI 工具与工作流教程`
      : `© ${year} Conduit AI Blog · AI tools & workflow guides`}
  </p>
</footer>

<style>
  footer { max-width: 760px; margin: 3rem auto 2rem; padding: 1.5rem 1.2rem 0; border-top: 1px solid var(--border); }
  footer p { color: var(--text-faint); font-size: 0.85rem; margin: 0; }
</style>
