---
import { UI, type LocaleCode } from '../i18n/config';
interface Props { lang?: LocaleCode; }
const { lang = 'zh' } = Astro.props;
const year = new Date().getFullYear();
const text = UI[lang].footer.replace('{year}', String(year));
---
<footer>
  <p>{text}</p>
</footer>

<style>
  footer { max-width: 760px; margin: 3rem auto 2rem; padding: 1.5rem 1.2rem 0; border-top: 1px solid var(--border); }
  footer p { color: var(--text-faint); font-size: 0.85rem; margin: 0; }
</style>
