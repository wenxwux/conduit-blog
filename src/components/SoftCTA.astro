---
// 平台软引导组件 —— 「平台软广」文案集中管理处，改口径/查红线只看 i18n/config.ts 的 UI[lang].softcta
// 用法：<SoftCTA lang="zh" /> / "en" / "ja" / "ko" / "es"
import { UI, PLATFORM_SITE, type LocaleCode } from '../i18n/config';
interface Props { lang?: LocaleCode; }
const { lang = 'zh' } = Astro.props;
const t = UI[lang].softcta;
---
<aside class="softcta">
  <p>
    <span set:html={t.body} />
    <a href={PLATFORM_SITE} target="_blank" rel="noopener">{t.linkText}</a>
  </p>
</aside>

<style>
  .softcta {
    margin: 2.5rem 0 0;
    padding: 1.1rem 1.3rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    background: var(--surface);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-soft);
  }
  .softcta strong { color: var(--text); }
  .softcta a { color: var(--accent); font-weight: 600; white-space: nowrap; }
</style>
