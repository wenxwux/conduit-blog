---
import BaseLayout from './BaseLayout.astro';
import SoftCTA from '../components/SoftCTA.astro';
import { localeOf, UI, type LocaleCode } from '../i18n/config';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  cover?: string;
  keywords?: string[];
  lang?: LocaleCode;
  altSlug?: string;
  availableLocales?: LocaleCode[];
}
const {
  title, description, pubDate, updatedDate,
  tags = [], cover, keywords = [], lang = 'zh', altSlug, availableLocales,
} = Astro.props;

const locale = localeOf(lang).dateLocale;
const fmt = (d: Date) => d.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title={title}
  description={description}
  lang={lang}
  cover={cover}
  type="article"
  altSlug={altSlug}
  keywords={keywords}
  availableLocales={availableLocales}
>
  <article class="post">
    <header>
      <h1>{title}</h1>
      <p class="meta">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {updatedDate && <span>· {UI[lang].updatedLabel} {fmt(updatedDate)}</span>}
      </p>
      {tags.length > 0 && (
        <ul class="tags">{tags.map((t) => <li>#{t}</li>)}</ul>
      )}
    </header>
    <div class="content">
      <slot />
    </div>
    <SoftCTA lang={lang} />
  </article>
</BaseLayout>

<style>
  .post { max-width: 760px; margin: 0 auto; padding: 1rem 1.2rem; }
  .post h1 { font-size: 1.9rem; line-height: 1.25; letter-spacing: -0.02em; margin: 0.5rem 0 0.6rem; }
  .meta { color: var(--text-faint); font-size: 0.85rem; margin: 0 0 0.8rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; list-style: none; padding: 0; margin: 0 0 1.5rem; }
  .tags li { font-size: 0.8rem; color: var(--accent); }
  .content :global(h2) { font-size: 1.35rem; margin: 2rem 0 0.7rem; }
  .content :global(h3) { font-size: 1.1rem; margin: 1.4rem 0 0.5rem; }
  .content :global(p) { margin: 0.9rem 0; }
  .content :global(ul), .content :global(ol) { padding-left: 1.3rem; }
  .content :global(li) { margin: 0.35rem 0; }
  .content :global(pre) { background: var(--code-bg); padding: 1rem; border-radius: 8px; overflow-x: auto; font-size: 0.85rem; }
  .content :global(code) { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .content :global(:not(pre) > code) { background: var(--code-bg); padding: 0.1rem 0.35rem; border-radius: 4px; font-size: 0.85em; }
  .content :global(a) { color: var(--accent); }
  .content :global(table) { width: 100%; border-collapse: collapse; font-size: 0.9rem; margin: 1rem 0; }
  .content :global(th), .content :global(td) { border: 1px solid var(--border); padding: 0.5rem 0.7rem; text-align: left; }
</style>
