---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { UI } from '../../../i18n/config';

const lang = 'ja' as const;
const t = UI[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog-ja', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title={t.blogIndexMeta.title} description={t.blogIndexMeta.desc} lang={lang}>
  <section class="list">
    <h1>{t.blogIndex.h1}</h1>
    {posts.length === 0 ? (
      <p class="empty">{t.blogIndex.empty}</p>
    ) : (
      <ul>
        {posts.map((p) => (
          <li>
            <a href={`${base}/ja/blog/${p.slug}`}>
              <span class="t">{p.data.title}</span>
              <span class="d">{p.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .list { max-width: 760px; margin: 0 auto; padding: 2rem 1.2rem; }
  .list h1 { font-size: 1.8rem; margin: 0 0 1.2rem; }
  .list ul { list-style: none; padding: 0; margin: 0; }
  .list li { border-top: 1px solid var(--border); }
  .list a { display: flex; flex-direction: column; gap: 0.25rem; padding: 1rem 0; text-decoration: none; }
  .list .t { color: var(--text); font-weight: 600; font-size: 1.05rem; }
  .list .d { color: var(--text-faint); font-size: 0.9rem; }
  .list a:hover .t { color: var(--accent); }
  .empty { color: var(--text-faint); }
</style>
